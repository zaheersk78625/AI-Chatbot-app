# GEMINI_API_KEY: Required for Gemini AI API calls.
# In Vercel, add this to the Environment Variables in the project settings.
GEMINI_API_KEY="your_gemini_api_key_here"

# VITE_ prefix is required for environment variables to be accessible in the frontend code.
# If you decide to move Firebase config to environment variables, use the VITE_ prefix.
# Example:
# VITE_FIREBASE_API_KEY="your_api_key"
